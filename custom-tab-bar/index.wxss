/* custom-tab-bar/index.wxss */
/* 盖州皮影戏 · 自定义底部导航 · 暗金舞台风格 */

.tabbar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: var(--z-tabbar, 1000);
  pointer-events: auto;
}

/* 顶部金辉细线 */
.tabbar-glow-line {
  width: 100%;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(212, 175, 55, 0.1) 20%,
    rgba(212, 175, 55, 0.6) 50%,
    rgba(212, 175, 55, 0.1) 80%,
    transparent 100%
  );
  box-shadow: 0 0 12rpx var(--gold-faint, rgba(212, 175, 55, 0.15));
}

.tabbar-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding-top: 16rpx;
  background-color: rgba(14, 8, 2, 0.97);
  background-image: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 3rpx,
    rgba(212, 175, 55, 0.018) 3rpx,
    rgba(212, 175, 55, 0.018) 4rpx
  );
  box-shadow:
    0 -4rpx 24rpx rgba(0, 0, 0, 0.6),
    inset 0 1rpx 0 rgba(212, 175, 55, 0.08);
}

/* 底部安全区 */
.tabbar-safe-area {
  width: 100%;
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  background-color: rgba(14, 8, 2, 0.97);
}

/* ── 单个 Tab 项 ── */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
  padding: 4rpx 0 14rpx;
  position: relative;
  transition: all var(--duration-fast, 150ms) var(--ease-out, ease);
}

/* 选中指示金粒（顶部小点） */
.tab-indicator {
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: var(--gold-primary, #D4AF37);
  border-radius: 50%;
  box-shadow: 0 0 12rpx var(--gold-glow, rgba(212, 175, 55, 0.5));
}

/* 图标区域 */
.tab-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
}

.tab-icon-emoji {
  font-size: 32rpx;
  line-height: 1;
  filter: grayscale(40%) opacity(0.35);
  transition: all var(--duration-fast, 150ms) var(--ease-out, ease);
}

.tab-label {
  font-size: var(--font-xs, 24rpx);
  color: rgba(255, 240, 200, 0.3);
  letter-spacing: 4rpx;
  font-family: var(--font-serif, "SimSun", "宋体", serif);
  font-weight: var(--weight-normal, 400);
  transition: color var(--duration-fast, 150ms) var(--ease-out, ease);
}

/* ── 激活态 ── */
.tab-active .tab-icon-emoji {
  filter: grayscale(0%) opacity(1);
  transform: scale(1.1);
}

.tab-active .tab-label {
  color: var(--gold-primary, #D4AF37);
  font-weight: var(--weight-bold, 700);
  text-shadow: 0 0 10rpx var(--gold-faint, rgba(212, 175, 55, 0.4));
}
