/* pages/elder-chat/elder-chat.wxss */
/* 盖州皮影作坊 — 舞台级AI人物对话 */

page { height: 100vh; overflow: hidden; background: #000; }
.page-root { position: relative; width: 100vw; height: 100vh; overflow: hidden; }

/* ======== 开场 ======== */
.intro-overlay { position: fixed; top:0; left:0; width:100%; height:100%; z-index:100; background: radial-gradient(ellipse at center, rgba(20,8,2,0.94) 0%, rgba(5,2,0,0.98) 100%); display:flex; align-items:center; justify-content:center; padding:60rpx; }
.intro-card { max-width:600rpx; display:flex; flex-direction:column; gap:32rpx; }
.intro-title { font-size:48rpx; font-weight:bold; color:#D4AF37; letter-spacing:8rpx; text-align:center; font-family:"SimSun","宋体",serif; }
.intro-text { font-size:30rpx; line-height:2; color:rgba(255,240,210,0.85); letter-spacing:2rpx; font-family:"SimSun","宋体",serif; }
.intro-cursor { width:4rpx; height:32rpx; background:#D4AF37; align-self:center; animation:cursorBlink 0.8s infinite; }
@keyframes cursorBlink { 0%,100%{opacity:1} 50%{opacity:0} }

/* ======== 场景页 ======== */
.scene-layer { position:absolute; top:0; left:0; width:100%; height:100%; z-index:10; }
.scene-bg { position:absolute; top:0; left:0; width:100%; height:100%; }
.scene-title-bar { position:absolute; top:calc(env(safe-area-inset-top) + 40rpx); left:0; right:0; display:flex; flex-direction:column; align-items:center; gap:8rpx; z-index:12; }
.scene-title { font-size:40rpx; font-weight:bold; color:#D4AF37; letter-spacing:6rpx; font-family:"SimSun","宋体",serif; text-shadow:0 2rpx 8rpx rgba(0,0,0,0.8); }
.scene-subtitle { font-size:24rpx; color:rgba(255,255,255,0.5); letter-spacing:2rpx; }
.hint-float { position:absolute; top:calc(env(safe-area-inset-top) + 150rpx); left:0; right:0; display:flex; justify-content:center; z-index:20; }
.hint-float text { font-size:26rpx; color:#D4AF37; background:rgba(0,0,0,0.6); padding:10rpx 28rpx; border-radius:20rpx; border:1rpx solid rgba(212,175,55,0.3); }
.char-spot { position:absolute; display:flex; flex-direction:column; align-items:center; gap:8rpx; transition:transform 0.25s,filter 0.25s; }
.char-img { width:160rpx; height:200rpx; transition:transform 0.25s,filter 0.25s; }
.char-label { padding:4rpx 18rpx; background:rgba(0,0,0,0.55); border:1rpx solid rgba(212,175,55,0.2); border-radius:14rpx; }
.char-label text { font-size:20rpx; color:rgba(255,255,255,0.6); letter-spacing:2rpx; }
.char-master { left:22%; top:28%; }
.char-young  { right:15%; top:32%; }
.char-teen   { left:25%; bottom:22%; }
.char-glow { transform:scale(1.12); z-index:15; }
.char-glow .char-img { filter:brightness(1.4) drop-shadow(0 0 16rpx rgba(212,175,55,0.7)); }
.char-glow .char-label { background:rgba(212,175,55,0.2); border-color:rgba(212,175,55,0.5); }
.char-glow .char-label text { color:#D4AF37; }

/* ======== 舞台人物页 ======== */
.stage-page {
  position:absolute; top:0; left:0; width:100%; height:100%; z-index:50;
  background: radial-gradient(ellipse at 50% 60%, #1a0e06 0%, #060302 100%);
  overflow: hidden;
}

/* 聚光灯 */
.spotlight {
  position:absolute; top:5%; left:15%; width:70%; height:85%;
  background: radial-gradient(ellipse at 50% 40%, rgba(212,175,55,0.12) 0%, rgba(212,175,55,0.04) 40%, transparent 70%);
  pointer-events: none; z-index:51;
}

/* 暗角 */
.vignette {
  position:absolute; top:0; left:0; width:100%; height:100%;
  box-shadow: inset 0 0 120rpx 40rpx rgba(0,0,0,0.7);
  pointer-events: none; z-index:52;
}

/* 舞台帷幕 */
.curtain {
  position:absolute; top:0; bottom:0; width:60rpx; z-index:53; pointer-events:none;
}
.curtain-left {
  left:0;
  background: linear-gradient(to right, rgba(80,15,10,0.7) 0%, rgba(60,10,5,0.5) 40%, rgba(40,5,2,0.15) 80%, transparent 100%);
  border-right: 2rpx solid rgba(180,120,30,0.25);
}
.curtain-right {
  right:0;
  background: linear-gradient(to left, rgba(80,15,10,0.7) 0%, rgba(60,10,5,0.5) 40%, rgba(40,5,2,0.15) 80%, transparent 100%);
  border-left: 2rpx solid rgba(180,120,30,0.25);
}
.curtain-top {
  position:absolute; top:0; left:0; right:0; height:50rpx; z-index:53; pointer-events:none;
  background: linear-gradient(to bottom, rgba(60,10,5,0.6) 0%, transparent 100%);
}

/* 漂浮粒子 */
.particles { position:absolute; top:0; left:0; width:100%; height:100%; z-index:51; pointer-events:none; }
.particle {
  position:absolute; bottom:-10rpx; border-radius:50%;
  background: rgba(212,175,55,0.25);
  animation: particleFloat linear infinite;
}
@keyframes particleFloat {
  0%   { transform:translateY(0) scale(1); opacity:0; }
  10%  { opacity:0.8; }
  90%  { opacity:0.5; }
  100% { transform:translateY(-110vh) scale(0.3); opacity:0; }
}

/* 返回 */
.st-back {
  position:absolute; top:calc(env(safe-area-inset-top) + 16rpx); left:20rpx; z-index:60;
  width:120rpx; height:56rpx;
  display:flex; align-items:center; justify-content:center;
  border:1rpx solid rgba(255,255,255,0.2); border-radius:16rpx;
  background:rgba(0,0,0,0.4);
}
.st-back text { font-size:24rpx; color:rgba(255,255,255,0.4); }

/* 名签 */
.st-nametag {
  position:absolute; top:calc(env(safe-area-inset-top) + 20rpx); right:24rpx; z-index:55;
  display:flex; flex-direction:column; align-items:flex-end; gap:2rpx;
}
.st-name { font-size:28rpx; color:#D4AF37; font-weight:bold; letter-spacing:4rpx; font-family:"SimSun","宋体",serif; }
.st-title { font-size:20rpx; color:rgba(255,255,255,0.35); letter-spacing:2rpx; }

/* 角色图 */
.st-char {
  position:absolute; top:10%; left:5%; width:90%; height:80%; z-index:52;
  filter: drop-shadow(0 0 40rpx rgba(0,0,0,0.6));
  transition: transform 2.5s ease-in-out;
}
.breath-up   { transform: translateY(-6rpx); }
.breath-down  { transform: translateY(0); }
.char-pulse { animation: charPulse 0.25s ease-in-out infinite alternate; }
@keyframes charPulse {
  from { transform: scale(1); }
  to   { transform: scale(1.03); }
}

/* 字幕通用 */
.st-subtitle {
  position:absolute; left:40rpx; right:40rpx; z-index:56;
  display:flex; align-items:center; justify-content:center;
}
.st-sub-user { top:30%; }
.st-sub-user text {
  font-size:28rpx; color:rgba(255,255,255,0.65);
  background:rgba(0,0,0,0.5); padding:10rpx 24rpx; border-radius:12rpx;
  letter-spacing:2rpx; max-width:80%; text-align:center;
}
.st-sub-ai { bottom:24%; }
.sub-deco-l, .sub-deco-r {
  flex:1; height:1rpx;
  background:linear-gradient(to right, transparent, rgba(212,175,55,0.35), transparent);
}
.sub-text {
  font-size:30rpx; color:#D4AF37;
  padding:14rpx 30rpx;
  background:rgba(10,5,2,0.82);
  border:1rpx solid rgba(212,175,55,0.3);
  border-radius:14rpx;
  letter-spacing:3rpx; max-width:78%; text-align:center;
  font-family:"SimSun","宋体",serif; line-height:1.6;
}
.sub-cursor { color:#D4AF37; animation:cursorBlink 0.6s infinite; }

/* 思考动画 */
.st-sub-think { bottom:24%; }
.think-rings {
  display:flex; align-items:center; justify-content:center; gap:16rpx;
  padding:18rpx 36rpx; background:rgba(10,5,2,0.75);
  border:1rpx solid rgba(212,175,55,0.15); border-radius:16rpx;
}
.tr { width:14rpx; height:14rpx; border-radius:50%; background:rgba(212,175,55,0.4); animation:trPulse 1s ease-in-out infinite; }
.tr2{animation-delay:0.2s} .tr3{animation-delay:0.4s}
@keyframes trPulse { 0%,100%{opacity:0.25;transform:scale(0.6)} 50%{opacity:1;transform:scale(1.3)} }

/* 底部操作 */
.st-bar {
  position:absolute; bottom:0; left:0; right:0; z-index:57;
  padding:16rpx 28rpx; padding-bottom:calc(env(safe-area-inset-bottom) + 24rpx);
  display:flex; flex-direction:column; align-items:center; gap:10rpx;
  background:linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
}
.st-hint { font-size:22rpx; color:rgba(255,255,255,0.3); letter-spacing:2rpx; }
.st-hint-rec { color:rgba(255,110,70,0.7); animation:hintPulse 1s infinite; }
@keyframes hintPulse { 0%,100%{opacity:0.4} 50%{opacity:1} }
.st-row { display:flex; align-items:center; gap:14rpx; width:100%; }
.st-input {
  flex:1; height:68rpx; padding:0 24rpx;
  background:rgba(255,255,255,0.06); border:1rpx solid rgba(255,255,255,0.08);
  border-radius:34rpx; color:#fff; font-size:26rpx; box-sizing:border-box;
}
.input-focus { border-color:rgba(212,175,55,0.3) !important; background:rgba(255,255,255,0.1) !important; }

/* 麦克风 */
.st-mic-wrap { position:relative; width:80rpx; height:80rpx; display:flex; align-items:center; justify-content:center; }
.st-mic {
  width:68rpx; height:68rpx; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  background:rgba(212,175,55,0.12); border:1rpx solid rgba(212,175,55,0.25);
  position:relative; z-index:2;
}
.mic-icon { font-size:32rpx; }
.mic-on { background:rgba(255,80,60,0.2); border-color:rgba(255,80,60,0.4); }
.mic-off { opacity:0.2; pointer-events:none; }
.mic-ripple {
  position:absolute; top:-6rpx; left:-6rpx; right:-6rpx; bottom:-6rpx;
  border-radius:50%; border:2rpx solid rgba(255,80,60,0.4);
  animation:rippleOut 1s ease-out infinite; z-index:1;
}
@keyframes rippleOut {
  0%   { transform:scale(1); opacity:1; }
  100% { transform:scale(1.6); opacity:0; }
}

/* ======== 底部导航 ======== */
.tabbar {
  position:fixed; bottom:0; left:0; width:100%; z-index:80;
  display:flex; justify-content:space-around;
  padding-top:16rpx; padding-bottom:calc(env(safe-area-inset-bottom) + 16rpx);
  background:linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.5) 100%);
  border-top:1rpx solid rgba(212,175,55,0.2);
}
.tab-item { display:flex; flex-direction:column; align-items:center; gap:6rpx; flex:1; }
.tab-icon  { font-size:40rpx; color:rgba(255,255,255,0.4); }
.tab-label { font-size:22rpx; color:rgba(255,255,255,0.4); }
.tab-active .tab-icon, .tab-active .tab-label { color:#D4AF37; font-weight:bold; }
