/* index.wxss */

page {
  height: 100vh;
  background: #000;
}

/* ── 全局容器 ── */
.page-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* ── 背景图 z-index:1 ── */
.bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* ── 左上角标题区域 z-index:10 ── */
.title-area {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
  padding-top: calc(env(safe-area-inset-top) + 88rpx);
  padding-left: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.title-img {
  width: 530rpx;
}

.subtitle-wrap {
  margin-top: 12rpx;
}

.subtitle-en {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 4rpx;
  font-family: serif;
  line-height: 1.6;
}

.subtitle-gold {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #D4AF37;
  letter-spacing: 3rpx;
}

/* ── 左侧导航菜单 z-index:10 ── */
.left-nav {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
  padding: 40rpx 18rpx;
  background: linear-gradient(
    to right,
    rgba(0, 0, 0, 0.68) 0%,
    rgba(0, 0, 0, 0.08) 100%
  );
  border-radius: 0 28rpx 28rpx 0;
  border-right: 1rpx solid rgba(212, 175, 55, 0.18);
  border-top: 1rpx solid rgba(212, 175, 55, 0.12);
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.12);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.nav-icon {
  width: 96rpx;
  height: 96rpx;
  filter: drop-shadow(0 2rpx 8rpx rgba(212, 175, 55, 0.35));
}

.nav-text {
  font-size: 20rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
  writing-mode: horizontal-tb;
  font-family: "SimSun", "宋体", serif;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.8);
}

/* ── 舞台区域 z-index:5 ── */
.stage-wrap {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
  width: 100%;
  display: flex;
  justify-content: center;
}

.stage-img {
  width: 92%;
}

/* ── 底部悬浮卡片 z-index:15 ── */
.float-card {
  position: absolute;
  bottom: 148rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 15;
  width: 580rpx;
  /* 敦煌暗棕底色 + 细噪点纹理模拟 */
  background-color: rgba(28, 16, 6, 0.93);
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3rpx,
      rgba(212, 175, 55, 0.025) 3rpx,
      rgba(212, 175, 55, 0.025) 4rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 3rpx,
      rgba(180, 120, 30, 0.02) 3rpx,
      rgba(180, 120, 30, 0.02) 4rpx
    );
  border: 1rpx solid rgba(212, 175, 55, 0.55);
  border-radius: 2rpx;
  padding: 36rpx 40rpx 30rpx;
  box-sizing: border-box;
  box-shadow:
    0 0 0 4rpx rgba(28, 16, 6, 0.6),
    0 0 0 5rpx rgba(212, 175, 55, 0.2),
    0 8rpx 40rpx rgba(0, 0, 0, 0.7),
    inset 0 0 40rpx rgba(180, 100, 20, 0.08);
}

/* 四角装饰 */
.card-corner {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
}

.card-corner-tl {
  top: 8rpx;
  left: 8rpx;
  border-top: 2rpx solid #D4AF37;
  border-left: 2rpx solid #D4AF37;
}

.card-corner-tr {
  top: 8rpx;
  right: 8rpx;
  border-top: 2rpx solid #D4AF37;
  border-right: 2rpx solid #D4AF37;
}

.card-corner-bl {
  bottom: 8rpx;
  left: 8rpx;
  border-bottom: 2rpx solid #D4AF37;
  border-left: 2rpx solid #D4AF37;
}

.card-corner-br {
  bottom: 8rpx;
  right: 8rpx;
  border-bottom: 2rpx solid #D4AF37;
  border-right: 2rpx solid #D4AF37;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
}

.card-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #D4AF37;
  letter-spacing: 6rpx;
  font-family: "SimSun", "宋体", serif;
  text-shadow: 0 0 24rpx rgba(212, 175, 55, 0.5), 0 2rpx 4rpx rgba(0,0,0,0.8);
  line-height: 1.2;
}

/* 分隔线：线 + 菱形 + 线 */
.card-divider {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin: 16rpx 0 14rpx;
  width: 100%;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(to right, rgba(212, 175, 55, 0.8), rgba(212, 175, 55, 0.15));
}

.card-divider .divider-line:last-child {
  background: linear-gradient(to left, rgba(212, 175, 55, 0.8), rgba(212, 175, 55, 0.15));
}

.divider-diamond {
  width: 10rpx;
  height: 10rpx;
  background: #D4AF37;
  transform: rotate(45deg);
  flex-shrink: 0;
  box-shadow: 0 0 8rpx rgba(212, 175, 55, 0.8);
}

.card-subtitle {
  font-size: 26rpx;
  color: rgba(255, 240, 200, 0.9);
  letter-spacing: 10rpx;
  font-family: "SimSun", "宋体", serif;
  line-height: 1.4;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.6);
}

.card-quote {
  font-size: 20rpx;
  color: rgba(212, 175, 55, 0.45);
  letter-spacing: 3rpx;
  font-family: "SimSun", "宋体", serif;
  margin-top: 14rpx;
  line-height: 1.6;
}

/* ── 右侧悬浮按钮 z-index:10 ── */
.float-btn {
  position: absolute;
  right: 28rpx;
  bottom: 260rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 76rpx;
  padding: 24rpx 0;
  border: 1rpx solid rgba(212, 175, 55, 0.8);
  border-radius: 38rpx;
  background: linear-gradient(
    180deg,
    rgba(18, 12, 2, 0.82) 0%,
    rgba(30, 20, 4, 0.75) 100%
  );
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.5), 0 0 16rpx rgba(212, 175, 55, 0.15), inset 0 1rpx 0 rgba(212, 175, 55, 0.25);
}

.play-icon {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 6rpx;
  opacity: 0.85;
}

.btn-text {
  font-size: 22rpx;
  color: #D4AF37;
  letter-spacing: 2rpx;
  line-height: 1.6;
  font-family: "SimSun", "宋体", serif;
  font-weight: bold;
  text-shadow: 0 0 10rpx rgba(212, 175, 55, 0.5);
}

/* ── 底部导航栏 z-index:20 ── */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 20;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding-top: 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  background-color: rgba(14, 8, 2, 0.97);
  background-image: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 3rpx,
    rgba(212, 175, 55, 0.018) 3rpx,
    rgba(212, 175, 55, 0.018) 4rpx
  );
  border-top: 1rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.6);
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  padding: 4rpx 0 8rpx;
  position: relative;
}

.tab-icon {
  font-size: 32rpx;
  color: rgba(255, 240, 200, 0.3);
  font-family: "SimSun", "宋体", serif;
  letter-spacing: 0;
  line-height: 1;
}

.tab-label {
  font-size: 24rpx;
  color: rgba(255, 240, 200, 0.3);
  letter-spacing: 4rpx;
  font-family: "SimSun", "宋体", serif;
  font-weight: normal;
}

/* 激活态：金色 + 顶部细线指示 */
.tab-active::before {
  content: "";
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  background: #D4AF37;
  border-radius: 2rpx;
  box-shadow: 0 0 10rpx rgba(212, 175, 55, 0.9);
}

.tab-active .tab-icon {
  color: #D4AF37;
  text-shadow: 0 0 16rpx rgba(212, 175, 55, 0.7);
}

.tab-active .tab-label {
  color: #D4AF37;
  font-weight: bold;
  letter-spacing: 4rpx;
  text-shadow: 0 0 10rpx rgba(212, 175, 55, 0.4);
}
