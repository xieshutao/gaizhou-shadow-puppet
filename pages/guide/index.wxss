/* pages/guide/index.wxss — 盖州皮影戏 · 导航中枢 */

page {
  height: 100vh;
  background: #0a0604;
  overflow: hidden;
  font-family: "SimSun", "宋体", serif;
}

/* ==================== 全局容器 ==================== */
.page-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* ==================== 舞台背景 ==================== */
.stage-bg {
  position: absolute;
  inset: 0;
  z-index: 1;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 80% 60% at 50% 40%,
    rgba(30, 15, 4, 0.9) 0%,
    rgba(10, 6, 4, 0.98) 60%,
    #0a0604 100%
  );
}

/* 舞台光晕 */
.stage-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.12;
  transition: opacity 2s ease;
}

.glow-1 {
  width: 500rpx;
  height: 500rpx;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
  background: radial-gradient(circle, #D4AF37 0%, transparent 70%);
}

.glow-2 {
  width: 400rpx;
  height: 400rpx;
  top: 25%;
  right: 10%;
  background: radial-gradient(circle, #C9A96E 0%, transparent 70%);
}

.glow-1.flicker { opacity: 0.25; }
.glow-2.flicker { opacity: 0.25; }

/* ==================== 金色粒子 ==================== */
.particle-container {
  position: absolute;
  inset: 0;
  z-index: 5;
}

.particle {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #D4AF37;
  border-radius: 50%;
  opacity: 0;
  animation: floatUp 6s ease-in infinite;
  box-shadow: 0 0 8rpx rgba(212, 175, 55, 0.6);
}

.p1 { left: 15%; animation-delay: 0s; }
.p2 { left: 30%; animation-delay: 1.2s; }
.p3 { left: 50%; animation-delay: 2.4s; }
.p4 { left: 65%; animation-delay: 3.6s; }
.p5 { left: 80%; animation-delay: 4.8s; }
.p6 { left: 20%; animation-delay: 0.8s; }
.p7 { left: 45%; animation-delay: 1.8s; }
.p8 { left: 72%; animation-delay: 3.0s; }

@keyframes floatUp {
  0%   { transform: translateY(100vh) scale(0); opacity: 0; }
  10%  { opacity: 0.8; }
  90%  { opacity: 0.2; }
  100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
}

/* ==================== 加载 & 欢迎阶段 ==================== */
.intro-overlay {
  position: absolute;
  inset: 0;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0a0604;
}

.loading-spinner {
  margin-bottom: 40rpx;
}

.spinner-ring {
  width: 80rpx;
  height: 80rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.2);
  border-top-color: #D4AF37;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(212, 175, 55, 0.7);
  letter-spacing: 6rpx;
}

/* 皮影剪影舞台 */
.silhouette-stage {
  position: relative;
  width: 500rpx;
  height: 400rpx;
  margin-bottom: 60rpx;
}

.silhouette-screen {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 440rpx;
  height: 300rpx;
  background: linear-gradient(
    to bottom,
    rgba(212, 175, 55, 0.08) 0%,
    rgba(212, 175, 55, 0.03) 100%
  );
  border: 1rpx solid rgba(212, 175, 55, 0.15);
  border-radius: 4rpx;
}

.silhouette-figure {
  position: absolute;
  bottom: 20rpx;
  width: 80rpx;
  height: 180rpx;
  background: rgba(10, 6, 4, 0.9);
  border: 2rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 6rpx;
  animation: figureSway 3s ease-in-out infinite;
}

.fig-left  { left: 60rpx;  animation-delay: 0s; }
.fig-right { right: 60rpx; animation-delay: 1.5s; }

@keyframes figureSway {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(8rpx) rotate(2deg); }
  75% { transform: translateX(-8rpx) rotate(-2deg); }
}

/* 欢迎文字 */
.welcome-text-box {
  padding: 0 60rpx;
}

.welcome-text {
  font-size: 36rpx;
  color: #D4AF37;
  letter-spacing: 4rpx;
  line-height: 2;
  text-align: center;
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.4);
  white-space: pre-line;
}

/* ==================== 主内容区 ==================== */
.main-content {
  position: relative;
  z-index: 10;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: 200rpx;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 品牌标识区 */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.brand-logo-wrap {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(212, 175, 55, 0.08);
  margin-bottom: 24rpx;
  box-shadow: 0 0 40rpx rgba(212, 175, 55, 0.15);
}

.brand-icon {
  font-size: 56rpx;
  color: #D4AF37;
}

.brand-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #D4AF37;
  letter-spacing: 8rpx;
  text-shadow: 0 0 24rpx rgba(212, 175, 55, 0.5);
  margin-bottom: 8rpx;
}

.brand-subtitle {
  font-size: 20rpx;
  color: rgba(212, 175, 55, 0.5);
  letter-spacing: 6rpx;
  margin-bottom: 20rpx;
}

.brand-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.line-seg {
  width: 80rpx;
  height: 1rpx;
  background: linear-gradient(to right, transparent, #D4AF37, transparent);
}

.line-dot {
  font-size: 16rpx;
  color: #D4AF37;
}

.brand-motto {
  font-size: 22rpx;
  color: rgba(212, 175, 55, 0.6);
  letter-spacing: 4rpx;
}

/* 登录区域 */
.login-area {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.login-btn {
  padding: 20rpx 80rpx;
  background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 32rpx rgba(212, 175, 55, 0.3);
  transition: transform 0.15s;
}

.login-btn:active {
  transform: scale(0.95);
}

.login-btn-text {
  font-size: 30rpx;
  color: #0a0604;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.login-hint {
  font-size: 24rpx;
  color: rgba(212, 175, 55, 0.45);
  letter-spacing: 2rpx;
}

.login-area.logged-in .user-greeting {
  font-size: 28rpx;
  color: #D4AF37;
  letter-spacing: 3rpx;
}

/* ==================== 导航卡片 ==================== */
.nav-grid {
  width: 640rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 0 20rpx;
}

.nav-card {
  position: relative;
  width: 100%;
}

.card-bg {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 32rpx;
  background: linear-gradient(
    135deg,
    rgba(28, 16, 6, 0.9) 0%,
    rgba(20, 12, 4, 0.95) 100%
  );
  border: 1rpx solid;
  border-radius: 8rpx;
  position: relative;
  z-index: 1;
  transition: transform 0.15s, box-shadow 0.15s;
}

.card-bg:active {
  transform: scale(0.98);
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-icon {
  font-size: 40rpx;
  font-family: "SimSun", "宋体", serif;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #D4AF37;
  letter-spacing: 3rpx;
}

.card-sub {
  font-size: 18rpx;
  color: rgba(212, 175, 55, 0.4);
  letter-spacing: 4rpx;
}

.card-desc {
  font-size: 22rpx;
  color: rgba(255, 240, 200, 0.5);
  letter-spacing: 1rpx;
}

.card-arrow {
  font-size: 32rpx;
  flex-shrink: 0;
}

/* 卡片四角 */
.card-corner {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  z-index: 2;
}

.c-tl { top: 6rpx; left: 6rpx; border-top: 2rpx solid; border-left: 2rpx solid; }
.c-tr { top: 6rpx; right: 6rpx; border-top: 2rpx solid; border-right: 2rpx solid; }
.c-bl { bottom: 6rpx; left: 6rpx; border-bottom: 2rpx solid; border-left: 2rpx solid; }
.c-br { bottom: 6rpx; right: 6rpx; border-bottom: 2rpx solid; border-right: 2rpx solid; }

/* ==================== 底部印章 ==================== */
.seal-area {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.seal-text {
  font-size: 28rpx;
  color: rgba(212, 175, 55, 0.35);
  letter-spacing: 8rpx;
}

.seal-text-sub {
  font-size: 20rpx;
  color: rgba(212, 175, 55, 0.2);
  letter-spacing: 6rpx;
}

/* ==================== 登录弹窗 ==================== */
.login-popup-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(4px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.login-popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.login-popup {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%) translateY(100%);
  z-index: 101;
  width: 100%;
  max-width: 640rpx;
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

.login-popup.show {
  transform: translateX(-50%) translateY(0);
}

.popup-bg {
  background: linear-gradient(
    to top,
    rgba(18, 10, 4, 0.98) 0%,
    rgba(28, 16, 6, 0.96) 100%
  );
  border-top: 2rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.5);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #D4AF37;
  letter-spacing: 4rpx;
}

.popup-close {
  font-size: 36rpx;
  color: rgba(212, 175, 55, 0.4);
  padding: 10rpx;
}

.popup-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(212, 175, 55, 0.1);
  border: 2rpx solid rgba(212, 175, 55, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 44rpx;
  color: #D4AF37;
}

.popup-desc {
  font-size: 26rpx;
  color: rgba(255, 240, 200, 0.7);
  letter-spacing: 2rpx;
}

.popup-features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-self: flex-start;
  padding-left: 40rpx;
}

.feature-item {
  font-size: 24rpx;
  color: rgba(255, 240, 200, 0.5);
  letter-spacing: 2rpx;
}

.popup-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-login {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
  border-radius: 50rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #0a0604;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 24rpx rgba(212, 175, 55, 0.3);
  transition: opacity 0.2s;
}

.btn-login:active { opacity: 0.85; }
.btn-login.loading { opacity: 0.6; }

.btn-skip {
  font-size: 24rpx;
  color: rgba(212, 175, 55, 0.45);
  letter-spacing: 2rpx;
  padding: 10rpx;
}

/* ==================== 底部导航栏 ==================== */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  padding-top: 16rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  background: linear-gradient(
    to top,
    rgba(10, 6, 4, 0.97) 0%,
    rgba(10, 6, 4, 0.7) 100%
  );
  border-top: 1rpx solid rgba(212, 175, 55, 0.2);
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.tab-icon {
  font-size: 38rpx;
  color: rgba(255, 255, 255, 0.35);
  font-family: "SimSun", "宋体", serif;
}

.tab-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 2rpx;
}

.tab-active .tab-icon {
  color: #D4AF37;
  text-shadow: 0 0 12rpx rgba(212, 175, 55, 0.5);
}

.tab-active .tab-label {
  color: #D4AF37;
  font-weight: bold;
}
