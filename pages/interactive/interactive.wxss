/* interactive.wxss */

page {
  height: 100vh;
  overflow: hidden;
  background: #000;
}

.page-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 全屏背景 */
.bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 三个功能按钮组 */
.nav-wrap {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  margin-bottom: 120rpx;
}

.nav-btn {
  width: 520rpx;
  transition: transform 0.15s ease, opacity 0.15s ease;
  transform: scale(1);
  opacity: 1;
}

.btn-press {
  transform: scale(0.93);
  opacity: 0.8;
}

/* 底部导航栏 */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 20;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  padding-top: 16rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.92) 0%,
    rgba(0, 0, 0, 0.6) 100%
  );
  border-top: 1rpx solid rgba(212, 175, 55, 0.25);
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.tab-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1;
}

.tab-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 1rpx;
}

.tab-active .tab-icon {
  color: #D4AF37;
}

.tab-active .tab-label {
  color: #D4AF37;
  font-weight: bold;
}
